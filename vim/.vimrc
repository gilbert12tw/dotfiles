syntax on
set ai
set sts=4
set tabstop=4
set shiftwidth=4
set ls=2
set expandtab
set autowrite
set smartindent
set mouse=a
set showmode
set showcmd
set whichwrap+=<,>,[,]
set timeoutlen=300
set hlsearch

set nu
set rnu

set cursorline
hi cursorline cterm=none ctermbg=89
highlight CursorLine cterm=none gui=underline

nnoremap y<CR> ggvG$"*y

inoremap kj <Esc>

