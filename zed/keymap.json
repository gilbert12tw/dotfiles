// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
    {
        "context": "Workspace",
        "bindings": {
            // "shift shift": "file_finder::Toggle"
        },
    },
    {
        "context": "Editor && vim_mode == insert",
        "bindings": {
            "k j": "vim::NormalBefore",
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "cmd-shift-g": "git_panel::ToggleFocus",
        },
    },
    {
        "context": "Terminal",
        "bindings": {
            "ctrl-h": "workspace::ActivatePaneLeft",
            "ctrl-k": "workspace::ActivatePaneUp",
        },
    },
    {
        "context": "Editor || ProjectPanel || GitPanel || OutlinePanel || CollabPanel || ChatPanel || DebugPanel || KeyContextView || EmptyPane || SharedScreen || MarkdownPreview",
        "bindings": {
            "ctrl-h": "workspace::ActivatePaneLeft",
            "ctrl-j": "workspace::ActivatePaneDown",
            "ctrl-k": "workspace::ActivatePaneUp",
            "ctrl-l": "workspace::ActivatePaneRight",
        },
    },
    {
        "context": "Pane",
        "unbind": {
            "cmd-shift-g": "search::SelectPreviousMatch"
        }
    },
    {
        "context": "vim_mode == insert",
        "unbind": {
            "ctrl-x ctrl-o": "editor::ShowCompletions"
        }
    },
    {
        "context": "vim_mode == insert && !(showing_code_actions || showing_completions)",
        "bindings": {
            "ctrl-y": "editor::ShowCompletions"
        }
    },
    {
        "context": "Editor",
        "unbind": {
            "ctrl-space": "editor::ShowCompletions"
        }
    },
    {
        "context": "vim_mode == insert && !(showing_code_actions || showing_completions)",
        "bindings": {
            "ctrl-n": "editor::ShowWordCompletions"
        }
    }
]
